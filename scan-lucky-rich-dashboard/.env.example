# ════════════════════════════════════════════════════════════════
# Dashboard env (julaherb-crm-board) — port 3101
# ════════════════════════════════════════════════════════════════

# ─── แหล่งข้อมูล ───────────────────────────────────────────────
# mock = ข้อมูล static (default, ปลอดภัย) | api = เรียก saversureV2 API
DATA_SOURCE=mock

# ─── saversureV2 API (ใช้เมื่อ DATA_SOURCE=api) ────────────────
# ⚠️ port 30400 base /api/v1 — dashboard เป็นแค่ consumer เรียก GET (read-only)
#    ห้ามเข้า DB saversure ตรง / ห้ามแตะโค้ด saversureV2
SAVERSURE_API_BASE_URL=http://localhost:30400/api/v1
# JWT bearer token (จาก backend saversureV2 — มี tenant_id ใน claim, ต้อง permission dashboard)
SAVERSURE_API_TOKEN=
# campaign ของ "สแกนลุ้นรวย" — ใส่ uuid ตรงๆ หรือเว้นว่างให้ระบบ lookup จากชื่อ
SAVERSURE_CAMPAIGN_ID=
SAVERSURE_CAMPAIGN_NAME=สแกนลุ้นรวย สวยลุ้นล้าน

# ─── (เดิม) ────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL เก่าชี้ :3001 (port saversureV1) — เลิกใช้ ใช้ DATA_SOURCE/SAVERSURE_* แทน
NEXT_PUBLIC_CAMPAIGN_ID=scan-lucky-rich-2569
